# Credenciais do Supabase (projeto que você já usa para os criativos da MCB)
# Copie este arquivo para ".env" e preencha com os seus valores.
# Pegue em: Supabase > Project Settings > API
#   - Project URL  -> VITE_SUPABASE_URL
#   - anon public  -> VITE_SUPABASE_ANON_KEY  (use a chave ANON/pública, NUNCA a service_role)

VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-chave-anon-publica-aqui
